# --- Postgres (used by docker-compose to init the DB container) ---
POSTGRES_USER=mediauser
POSTGRES_PASSWORD=abhi123
POSTGRES_DB=media_pipeline
POSTGRES_PORT=5432

# --- Redis (used by docker-compose to expose the port) ---
REDIS_PORT=6379

# NOTE: api/.env.example and worker/.env.example will hold app-level
